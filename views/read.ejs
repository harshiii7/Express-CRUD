<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/stylesheets/style.css">
        <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script> 
    <title>Document</title>
</head>
<body>
    <div class="w-full min-h-screen bg-zinc-900 p-10 text-white">
        <a href="./" class="relative group w-fit flex items-center">
  <img 
    src="https://cdn-icons-png.flaticon.com/512/9385/9385258.png"
    alt="Home"
    class="h-8 w-8"
  >

  <!-- Tooltip -->
  <span class="absolute left-full top-1/2 -translate-y-1/2 ml-2
               opacity-0 group-hover:opacity-100
               transition bg-black text-white text-xs
               px-2 py-1 rounded whitespace-nowrap
               pointer-events-none">
    Back to home
  </span>
</a>

        <!-- <a class=" flex text-blue-600" href="./"><img src="https://cdn-icons-png.flaticon.com/512/9385/9385258.png" alt="" class="h-8 w-8 "></a> -->
        <h1 class="text-3xl tracking-tighter mb-3 mt-10">All Users</h1>
        <div class="users flex gap-15 flex-wrap">
            <% if(users.length > 0 ){ %> <!-- <% %> -> ye loop k liye use hota hai-->
                <% users.forEach(function(user){ %>
                <div class="user w-72 p-4 bg-zinc-800 rounded-lg">
                <div class="w-full h-52 rounded-lg bg-blue-500 overflow-hidden">
                    <img class="w-full h-full object-cover object-top" src="<%= user.image %>" alt=""><!-- <%= %> -> ye print karne k liye use hita hai-->
                </div>
                <h3 class="text-xl mt-3 tracking-tighter"><%= user.name %></h3>
                <h5 class="text-zinc-500"><%= user.email %></h5>
                <div class="flex gap-26 mt-10">
                    <a class="text-zinc-200" href="/edit/<%= user._id %>">Edit User</a>
                    <a class="text-red-500 " href="/delete/<%= user._id %>">Delete User</a>
                </div>
                </div>
               <% }) %>
            <% } else { %>
                <h3 class="text-zinc-500">no user yet</h3>
            <% } %>
           
           
        </div>
    </div>
</body>
</html>