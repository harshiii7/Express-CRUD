<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/stylesheets/style.css">
        <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script> 
    <title>Document</title>
</head>
<body>
    <div class="w-full h-full bg-zinc-900 p-10 text-white">
        <a href="./read" class="relative group w-fit flex items-center">
            <img 
                src="https://cdn-icons-png.flaticon.com/512/3177/3177440.png"
                alt="user"
                class="h-8 w-8"
            >

            <!-- Tooltip -->
            <span class="absolute left-full top-1/2 -translate-y-1/2 ml-2
                        opacity-0 group-hover:opacity-100
                        transition bg-blue-500 text-white text-xs
                        px-2 py-1 rounded whitespace-nowrap
                        pointer-events-none">
                Show All User
            </span>
        </a>

        <!-- <a class="text-blue-600" href="./read " title="Back to Home"><img src="https://cdn-icons-png.flaticon.com/512/3177/3177440.png" alt="Home" class="h-8 w-8"></a> -->
        <h1 class="text-3xl tracking-tighter mb-3 mt-10">Create User</h1>
        <form action="/create" method="post"> 
            <input class="px-5 py-2 border-2 border-zinc-800 rounded-lg outlint-none bg-transprent" type="text" name="name" placeholder="name">
            <input class="px-5 py-2 border-2 border-zinc-800 rounded-lg outlint-none bg-transprent" type="text" name="email" placeholder="email">
            <input class="px-5 py-2 border-2 border-zinc-800 rounded-lg outlint-none bg-transprent" type="text" name="image" placeholder="image url">
            <input class="px-5 py-2 bg-blue-600 rounded-lg" type="submit" value="Create User">
        </form>
       
         
    
    </div>
</body>
</html>