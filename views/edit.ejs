<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/stylesheets/style.css">
        <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script> 
    <title>Document</title>
</head>
<body>
    <div class="w-full h-full bg-zinc-900 p-10 text-white">
        <!-- <a class="text-blue-600" href="./read ">Show User</a> -->
        <h1 class="text-3xl tracking-tighter mb-3 mt-10">Update User</h1>
        <form action="/update/<%= users._id%>" method="post"> 
            <input class="px-5 py-2 border-2 border-zinc-800 rounded-lg outlint-none bg-transprent" type="text" name="name" placeholder="name" value="<%= users.name %>">
            <input class="px-5 py-2 border-2 border-zinc-800 rounded-lg outlint-none bg-transprent" type="text" name="email" placeholder="email" value="<%= users.email %>">
            <input class="px-5 py-2 border-2 border-zinc-800 rounded-lg outlint-none bg-transprent" type="text" name="image" placeholder="image url" value="<%= users.image %>">
            <input class="px-5 py-2 bg-yellow-600 text-black rounded-lg" type="submit" value="Update User">
        </form>
    </div>
</body>
</html>